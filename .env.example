NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# チーム動作確認用の「無認証プレビュー」を本番デプロイ(Vercel等)でも許可するフラグ。
# "1" を設定すると、Supabase 未設定でも /dashboard をログイン無しで閲覧できる。
# ⚠ URL を知る誰でも管理画面を見られる状態になる。実顧客データを入れる前に必ず外すこと（モックデータ確認用の暫定）。
# 未設定（既定）なら本番は fail-closed（ログイン必須）。
NEXT_PUBLIC_ALLOW_PREVIEW=

# 管理画面(/dashboard)に入れるスタッフ/管理者のメール許可リスト（カンマ区切り・サーバー専用）。
# 公開予約サイトと同じ Supabase Auth を共有するため、これが空だと本番では管理画面アクセスを拒否する（fail-closed）。
# 例: STAFF_EMAIL_ALLOWLIST=owner@example.com,staff@example.com
# 恒久対応（users/user_roles による RBAC）が入るまでの暫定。NEXT_PUBLIC を付けないこと（ブラウザに露出させない）。
STAFF_EMAIL_ALLOWLIST=

# ChatGPT consultation (optional — used by scripts/ask-chatgpt.mjs)
OPENAI_API_KEY=
